{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["iad1"],
  "env": {
    "DATABASE_URL": "@database-url",
    "NEXTAUTH_SECRET": "@nextauth-secret",
    "STRIPE_SECRET_KEY": "@stripe-secret-key",
    "STRIPE_WEBHOOK_SECRET": "@stripe-webhook-secret"
  },
  "crons": [
    { "path": "/api/lifecycle?trigger=refill_reminders", "schedule": "0 6 * * *" },
    { "path": "/api/lifecycle?trigger=milestone_check", "schedule": "0 10 * * *" },
    { "path": "/api/lifecycle?trigger=quiz_abandonment", "schedule": "0 14 * * *" },
    { "path": "/api/lifecycle?trigger=reactivation", "schedule": "0 8 * * 1" },
    { "path": "/api/lifecycle?trigger=checkout_abandonment", "schedule": "0 */4 * * *" },
    { "path": "/api/cron/lifecycle", "schedule": "15 * * * *" }
  ]
}
