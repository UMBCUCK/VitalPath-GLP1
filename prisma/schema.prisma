// ─── RESELLER / SELLER PROFILES ─────────────────────────────

model ResellerProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  displayName       String
  companyName       String?
  contactEmail      String
  contactPhone      String?
  tier              String   @default("STANDARD") // STANDARD, SILVER, GOLD, AMBASSADOR, CUSTOM
  status            String   @default("ACTIVE")   // ACTIVE, SUSPENDED, PAUSED, TERMINATED

  // Commission config (overrides global referral settings)
  commissionType    String   @default("PERCENTAGE") // PERCENTAGE, FLAT, TIERED
  commissionPct     Float?   // e.g. 15.0 for 15%
  commissionFlat    Int?     // flat cents per sale
  commissionCap     Int?     // max total payout per month in cents
  tieredRates       Json?    // [{minSales: 0, maxSales: 10, rate: 10}, {minSales: 11, rate: 15}]

  // Subscription commission controls
  subscriptionCommissionEnabled Boolean @default(true)  // admin can disable recurring commissions
  subscriptionCommissionPct     Float?  // override % for recurring vs one-time
  maxRecurringMonths            Int?    // limit recurring commissions to N months (null = forever)

  // Performance tracking
  totalSales        Int      @default(0)
  totalRevenue      Int      @default(0) // cents generated
  totalCommission   Int      @default(0) // cents earned
  totalCustomers    Int      @default(0)
  conversionRate    Float?   // click-to-sale %
  lastSaleAt        DateTime?

  // Multi-tier referral network (legally structured as referral bonuses)
  referredByResellerId  String?   // the reseller who recruited this reseller (tier 1 upline)
  networkDepth          Int       @default(0) // 0 = top-level, 1 = referred by tier 0, etc. Max 3.
  referralCode          String?   @unique // unique code for this reseller to recruit sub-resellers
  totalSubResellers     Int       @default(0)
  totalNetworkRevenue   Int       @default(0) // cents - total revenue from entire downline
  totalOverrideEarnings Int       @default(0) // cents - total override commissions earned

  // Override commission rates — DISABLED for healthcare compliance (AKS/FTC)
  // Retained for analytics only; all values must remain 0.0 in production
  tier1OverridePct      Float     @default(0.0)  // DISABLED — was % of Tier 1 override
  tier2OverridePct      Float     @default(0.0)  // DISABLED — was % of Tier 2 override
  tier3OverridePct      Float     @default(0.0)  // DISABLED — was % of Tier 3 override

  // ─── Compliance & Onboarding ────────────────────────────────
  onboardingStep                Int       @default(0) // 0-7 tracks progress through required onboarding
  onboardingCompletedAt         DateTime?             // null = not yet completed
  complianceTrainingCompletedAt DateTime?             // when they finished the compliance training module
  agreementSignedAt             DateTime?             // when they signed the reseller agreement
  agreementVersion              String?               // e.g. "2026-04-01-v1" — tracks which version they signed
  agreementIpAddress            String?               // IP address when agreement was signed
  w9SubmittedAt                 DateTime?             // when W-9 was submitted (required before payout)
  w9LegalName                   String?               // legal name on W-9
  w9BusinessName                String?               // business name (if different)
  w9TaxClassification           String?               // INDIVIDUAL, C_CORP, S_CORP, PARTNERSHIP, LLC, OTHER
  w9AddressLine1                String?
  w9City                        String?
  w9State                       String?
  w9Zip                         String?
  w9TinType                     String?               // SSN or EIN
  w9TinLast4                    String?               // last 4 digits only (never store full TIN)
  w9CertificationSignedAt       DateTime?             // electronic signature timestamp
  oigCheckPassedAt              DateTime?             // OIG exclusion database check
  oigCheckResult                String?               // CLEAR or FLAGGED
  samCheckPassedAt              DateTime?             // SAM.gov check
  samCheckResult                String?               // CLEAR or FLAGGED
  healthcareProviderAttestation Boolean   @default(false) // attests they are NOT a licensed provider
  attestationSignedAt           DateTime?
  marketingApprovalRequired     Boolean   @default(true) // must use pre-approved materials only
  lastComplianceAuditAt         DateTime?             // last time admin reviewed their marketing
  complianceViolationCount      Int       @default(0) // tracked for auto-suspension

  // Payout preferences
  payoutMethod          String    @default("CREDIT") // CREDIT, BANK_ACH, CHECK
  payoutBankName        String?
  payoutAccountLast4    String?
  payoutRoutingLast4    String?
  taxIdProvided         Boolean   @default(false) // W-9 on file
  taxId1099Eligible     Boolean   @default(false) // earnings >= $600/year threshold

  // Admin notes
  adminNotes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  commissions Commission[]

  @@index([status])
  @@index([tier])
  @@index([referredByResellerId])
  @@index([referralCode])
}

model Commission {
  id              String   @id @default(cuid())
  resellerId      String
  orderId         String?
  subscriptionId  String?
  customerId      String?  // the referred customer
  type            String   // INITIAL_SALE, RECURRING, BONUS, ADJUSTMENT, OVERRIDE_TIER1, OVERRIDE_TIER2, OVERRIDE_TIER3
  amountCents     Int
  status          String   @default("PENDING") // PENDING, APPROVED, PAID, REJECTED, CLAWBACK
  paidAt          DateTime?
  periodStart     DateTime? // for recurring commissions
  periodEnd       DateTime?
  notes           String?

  // Override tracking (for multi-tier referral bonuses)
  sourceResellerId  String?  // the reseller whose sale generated this override
  overrideTier      Int?     // 1, 2, or 3 — which tier of the network this came from
  sourceCommissionId String? // the original commission this override was generated from

  createdAt       DateTime @default(now())

  reseller ResellerProfile @relation(fields: [resellerId], references: [id], onDelete: Cascade)

  @@index([resellerId])
  @@index([customerId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([sourceResellerId])
}

// ─── RESELLER NETWORK TRACKING ──────────────────────────────
// Legally structured as a Referral Bonus Program:
// - Compensation is based ONLY on actual product/service sales to end consumers
// - No compensation for recruiting resellers — override bonuses are tied to sales volume
// - Maximum 3 tiers (direct, 2nd-level, 3rd-level) — compliant with FTC guidelines
// - No inventory purchase requirements
// - No minimum sales quotas to earn overrides
// - Reseller Agreement required with full disclosure of compensation structure

model ResellerNetworkEvent {
  id              String   @id @default(cuid())
  eventType       String   // RECRUIT, SALE, OVERRIDE_PAID, TIER_UPGRADE, DEACTIVATION
  resellerId      String   // the reseller this event is about
  relatedResellerId String? // for RECRUIT: who recruited them. For OVERRIDE: who generated the sale
  tier            Int?     // network tier level
  amountCents     Int?     // for financial events
  metadata        Json?    // additional context
  createdAt       DateTime @default(now())

  @@index([resellerId])
  @@index([eventType])
  @@index([createdAt])
}

// ─── AI REPORT GENERATION ───────────────────────────────────

model AIReport {
  id           String   @id @default(cuid())
  title        String
  reportType   String   // FULL_ANALYTICS, CONVERSION_OPTIMIZATION, SALES_PERFORMANCE, FINANCIAL, CUSTOM
  content      String   // markdown content generated by Claude
  summary      String?  // executive summary
  suggestions  Json?    // structured improvement suggestions
  dataSnapshot Json?    // the analytics data that was analyzed
  tokenUsage   Int?     // API tokens used
  generatedBy  String   // admin userId
  createdAt    DateTime @default(now())

  @@index([reportType])
  @@index([createdAt])
}

// ─── DYNAMIC PRICING ────────────────────────────────────────

model PricingRule {
