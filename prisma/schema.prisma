// ─── CONTENT RECOMMENDATIONS ────────────────────────────────

model ContentRecommendation {
  id          String   @id @default(cuid())
  userId      String
  contentType String   // BLOG_POST, RECIPE, MEAL_PLAN
  contentId   String
  score       Float    // relevance score 0-100
  reason      String   // why recommended
  wasViewed   Boolean  @default(false)
  wasClicked  Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([contentType])
  @@index([score])
}

// ─── RESELLER PORTAL ACCESS ─────────────────────────────────

model ResellerSession {
  id          String   @id @default(cuid())
  resellerId  String
  token       String   @unique
  expiresAt   DateTime
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([token])
  @@index([resellerId])
}

// ─── DASHBOARD WIDGET LAYOUTS ───────────────────────────────

model WidgetLayout {
  id        String   @id @default(cuid())
  adminId   String   @unique
  widgets   Json     // [{id, type, position: {x,y,w,h}, config}]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── RESELLER MARKETING ASSETS ──────────────────────────────

model MarketingAsset {
  id          String   @id @default(cuid())
  name        String
  type        String   // BANNER, EMAIL_TEMPLATE, SOCIAL_POST, LANDING_PAGE, DOCUMENT
  fileUrl     String?
  content     String?  // for text-based assets like email templates
  thumbnail   String?
  category    String?
  isActive    Boolean  @default(true)
  downloads   Int      @default(0)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([isActive])
}

// ─── INVENTORY & SUPPLY CHAIN ───────────────────────────────

model InventoryRecord {
  id              String   @id @default(cuid())
  medicationName  String
  pharmacyVendor  String
  currentStock    Int      // units available
  reorderThreshold Int     // reorder when stock falls below this
  reorderQuantity Int      // how many to order
  unitCostCents   Int?     // cost per unit
  lastRestockedAt DateTime?
  estimatedRunout DateTime? // predicted date stock runs out
  status          String   @default("IN_STOCK") // IN_STOCK, LOW_STOCK, OUT_OF_STOCK, ON_ORDER
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([medicationName])
  @@index([pharmacyVendor])
}

// ─── OUTCOME REPORTS ────────────────────────────────────────

model OutcomeReport {
  id           String   @id @default(cuid())
  title        String
  reportType   String   // AGGREGATE, PROVIDER, MEDICATION, PLAN, PUBLISHABLE
  periodStart  DateTime
  periodEnd    DateTime
  metrics      Json     // { avgWeightLoss, avgAdherence, retentionRate, satisfactionScore, etc }
  breakdown    Json?    // per-plan or per-provider breakdown
  isPublishable Boolean @default(false)
  complianceApproved Boolean @default(false)
  approvedBy   String?
  generatedBy  String
  createdAt    DateTime @default(now())

  @@index([reportType])
  @@index([createdAt])
}

// ─── CURRENCY & TAX CONFIG ──────────────────────────────────

model CurrencyConfig {
  id            String  @id @default(cuid())
  currencyCode  String  @unique // USD, CAD, EUR, GBP
  symbol        String  // $, C$, etc
  exchangeRate  Float   @default(1.0) // relative to USD
  isActive      Boolean @default(true)
  updatedAt     DateTime @updatedAt
}

model TaxRule {
  id          String  @id @default(cuid())
  jurisdiction String // state code or country code
  taxRate     Float   // e.g. 0.0825 for 8.25%
  taxName     String  // "Sales Tax", "HST", "VAT"
  appliesTo   String  @default("ALL") // ALL, MEMBERSHIP, ADDON, SUPPLEMENT
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([jurisdiction, appliesTo])
  @@index([jurisdiction])
  @@index([isActive])
}

// ─── MULTI-TOUCH ATTRIBUTION ────────────────────────────────

model AttributionTouch {
  id          String   @id @default(cuid())
  leadId      String?
  userId      String?
  sessionId   String?
  touchType   String   // FIRST_CLICK, LAST_CLICK, ASSIST
  channel     String   // organic, paid, referral, email, social, direct
  source      String?  // google, facebook, newsletter, partner_name
  medium      String?  // cpc, email, referral
  campaign    String?
  content     String?  // ad variant, blog slug, email name
  landingPage String?
  convertedAt DateTime?
  revenueCents Int?
  createdAt   DateTime @default(now())

  @@index([leadId])
  @@index([userId])
  @@index([channel])
  @@index([source])
  @@index([createdAt])
}

// ─── RETENTION PLAYBOOKS ────────────────────────────────────

model RetentionPlaybook {
  id          String   @id @default(cuid())
  name        String
  triggerType String   // ONBOARDING, INACTIVITY, CHURN_RISK, WIN_BACK, MILESTONE
  triggerConfig Json   // { daysInactive, churnRiskThreshold, daysSinceCancel, milestoneType }
  steps       Json     // [{ dayOffset, action, channel, templateKey, subject, body }]
  isActive    Boolean  @default(true)
  enrolledCount Int    @default(0)
  completedCount Int   @default(0)
  convertedCount Int   @default(0)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  enrollments PlaybookEnrollment[]

  @@index([triggerType])
  @@index([isActive])
}

model PlaybookEnrollment {
  id          String    @id @default(cuid())
  playbookId  String
  userId      String
  status      String    @default("ACTIVE") // ACTIVE, COMPLETED, CONVERTED, EXITED
  currentStep Int       @default(0)
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?
  convertedAt DateTime?
  exitedAt    DateTime?
  exitReason  String?

  playbook RetentionPlaybook @relation(fields: [playbookId], references: [id], onDelete: Cascade)

  @@unique([playbookId, userId])
  @@index([playbookId])
  @@index([userId])
  @@index([status])
}

// ─── PROVIDER SCORECARDS ────────────────────────────────────

model ProviderScorecard {
  id                   String   @id @default(cuid())
  providerId           String
  periodStart          DateTime
  periodEnd            DateTime
  totalPatients        Int      @default(0)
  consultationsCompleted Int    @default(0)
  avgResponseTime      Float?   // hours
  patientSatisfaction  Float?   // 0-5
  avgWeightLoss        Float?   // lbs
  adherenceRate        Float?   // 0-100%
  prescriptionAccuracy Float?   // 0-100%
  credentialScore      Float?   // 0-100% compliance
  overallScore         Float?   // composite 0-100
  createdAt            DateTime @default(now())

  @@index([providerId])
  @@index([periodStart])
}

// ─── ADVANCED SEGMENTS ──────────────────────────────────────

model AdvancedSegment {
  id          String   @id @default(cuid())
  name        String
  description String?
  rules       Json     // { operator: "AND"|"OR", conditions: [{field, op, value, group?}] }
  memberCount Int      @default(0)
  lastComputedAt DateTime?
  isActive    Boolean  @default(true)
  autoTrigger String?  // automation rule id to trigger when user enters segment
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}

// ─── REVENUE ATTRIBUTION ────────────────────────────────────

model RevenueAttribution {
  id           String   @id @default(cuid())
  orderId      String
  userId       String
  channel      String   // organic, paid, referral, email, social, direct
  source       String?
  campaign     String?
  contentPiece String?  // blog slug, email name, ad variant
  contentType  String?  // BLOG_POST, EMAIL, AD, REFERRAL
  revenueCents Int
  model        String   // FIRST_CLICK, LAST_CLICK, LINEAR
  weight       Float    @default(1.0) // for linear attribution
  createdAt    DateTime @default(now())

  @@index([orderId])
  @@index([userId])
  @@index([channel])
  @@index([contentPiece])
  @@index([model])
}

// ─── COMPLIANCE SCORES ──────────────────────────────────────

model ComplianceScore {
  id                   String   @id @default(cuid())
  entityType           String   // OVERALL, CONTENT, CLAIMS, CONSENTS, CREDENTIALS
  entityId             String?
  score                Float    // 0-100
  maxScore             Float    @default(100)
  breakdown            Json?    // { contentScore, claimsScore, consentScore, credentialScore }
  issues               Json?    // [{ type, description, severity }]
  computedAt           DateTime @default(now())

  @@index([entityType])
  @@index([computedAt])
}

// ─── PLATFORM HEALTH MONITORING ─────────────────────────────

model HealthCheck {
  id           String   @id @default(cuid())
  service      String   // API, DATABASE, STRIPE, OPENLOOP, PHARMACY, EMAIL
  status       String   // HEALTHY, DEGRADED, DOWN
  responseTime Int?     // ms
  errorMessage String?
  metadata     Json?
  checkedAt    DateTime @default(now())

  @@index([service])
  @@index([status])
  @@index([checkedAt])
}

model ErrorLog {
  id         String   @id @default(cuid())
  route      String   // API route path
  method     String   // GET, POST, PUT, DELETE
  statusCode Int
  message    String
  stack      String?
  userId     String?
  ipAddress  String?
  userAgent  String?
  duration   Int?     // ms
  createdAt  DateTime @default(now())

  @@index([route])
  @@index([statusCode])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════
// BILLION-DOLLAR SYSTEM MODELS
