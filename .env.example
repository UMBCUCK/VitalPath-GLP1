# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=VitalPath

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/vitalpath?schema=public

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs
NEXT_PUBLIC_STRIPE_ESSENTIAL_PRICE_ID=price_essential_monthly
NEXT_PUBLIC_STRIPE_PREMIUM_PRICE_ID=price_premium_monthly
NEXT_PUBLIC_STRIPE_COMPLETE_PRICE_ID=price_complete_monthly

# Auth (NextAuth or similar)
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=care@vitalpath.com

# SMS (Twilio)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Telehealth vendor (OpenLoop / Wheel / custom)
TELEHEALTH_VENDOR=openloop
TELEHEALTH_API_KEY=...
TELEHEALTH_API_URL=https://api.openloophealth.com/v1
TELEHEALTH_WEBHOOK_SECRET=...

# Pharmacy vendor
PHARMACY_VENDOR=generic
PHARMACY_API_KEY=...
PHARMACY_API_URL=...

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-...
META_PIXEL_ID=...
META_CONVERSIONS_API_TOKEN=...

# Feature flags
NEXT_PUBLIC_ENABLE_REFERRALS=true
NEXT_PUBLIC_ENABLE_MEAL_PLANS=true
NEXT_PUBLIC_ENABLE_CALCULATORS=true
